{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BestStrat LLM Skill Input",
  "type": "object",
  "required": [
    "symbol",
    "timeframe",
    "lookbackDays",
    "riskLevel",
    "strategyFocus"
  ],
  "properties": {
    "symbol": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,15}$",
      "description": "Uppercase crypto symbol, for example CAKE, BNB, ETH."
    },
    "timeframe": {
      "type": "string",
      "enum": [
        "5m",
        "15m",
        "1h",
        "4h",
        "1d"
      ]
    },
    "lookbackDays": {
      "type": "integer",
      "enum": [
        7,
        14,
        30,
        60,
        90
      ]
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "conservative",
        "moderate",
        "aggressive"
      ]
    },
    "strategyFocus": {
      "type": "string",
      "enum": [
        "auto",
        "momentum",
        "sentiment_divergence",
        "regime_detection",
        "risk_off"
      ]
    }
  },
  "additionalProperties": false
}
